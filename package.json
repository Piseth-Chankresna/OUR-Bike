{
  "name": "our-bikes-store",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "ng test --code-coverage",
    "test:integration": "ng test --testName=Integration",
    "test:e2e": "ng e2e",
    "test:smoke": "ng e2e --config=smoke.config.ts",
    "test:performance": "lhci autorun",
    "test:accessibility": "pa11y-ci http://localhost:4200",
    "lint": "ng lint",
    "type-check": "tsc --noEmit",
    "analyze": "ng build --stats-json && npx webpack-bundle-analyzer dist/our-bikes-store/stats.json",
    "deploy:staging": "ng build --configuration staging && aws s3 sync dist/our-bikes-store/ s3://our-bikes-store-staging/ --delete",
    "deploy:production": "ng build --configuration production && aws s3 sync dist/our-bikes-store/ s3://our-bikes-store-prod/ --delete && aws cloudfront create-invalidation --distribution-id E1234567890ABC --paths \"/*\""
  },
  "private": true,
  "packageManager": "npm@11.8.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.3",
    "@angular/cli": "^21.2.3",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.12.0",
    "@playwright/test": "^1.40.0",
    "@types/jasmine": "~4.3.0",
    "@types/node": "^20.0.0",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "jasmine-core": "~4.6.0",
    "jsdom": "^28.0.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage-istanbul-reporter": "~3.0.3",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "pa11y-ci": "^4.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8",
    "webpack-bundle-analyzer": "^4.9.0"
  }
}
